// SECTION 3: REMOVE ALL MEMBERS FROM GROUPS
// ========================================

/**
 * Removes all members from specified groups
 */
function removeGroupMembersAndUpdateStatus() {
  const ui = SpreadsheetApp.getUi();
  const confirmWord = CONFIG.CONFIRMATION_WORDS.EMPTY_GROUPS;
  const message = `WARNING: You are about to remove ALL members from groups in Column A.\n\n` +
    `This is PERMANENT and cannot be undone.\n\n` +
    `Type "${confirmWord}" (all caps) to confirm.`;

  if (!showConfirmationDialog(confirmWord, 'DANGER: Confirm Removing ALL Group Members', message)) {
    ui.alert('Operation cancelled. No action taken.');
    return;
  }

  const sheet = SpreadsheetApp.getActiveSpreadsheet().getActiveSheet();
  const data = sheet.getDataRange().getValues();

  // Validate Admin SDK access
  const validation = validateAdminSDK('Groups');
  if (!validation.valid) {
    ui.alert(`Error: ${validation.error}`);
    return;
  }

  if (data.length < 1) {
    ui.alert('No data found.');
    return;
  }

  // Set up headers if missing
  if (!sheet.getRange(1, 1).getValue()) {
    sheet.getRange(1, 1).setValue('Group Email').setFontWeight('bold');
  }
  if (!sheet.getRange(1, 2).getValue()) {
    sheet.getRange(1, 2).setValue('Status').setFontWeight('bold');
  }

  let processedCount = 0;
  let errorCount = 0;

  // Process each group
  for (let i = 1; i < data.length; i++) {
    const groupEmail = getCellValue(data[i][0]);
    const statusCell = sheet.getRange(i + 1, 2);

    if (!groupEmail) {
      statusCell.setValue('Skipped: No group email');
      continue;
    }

    try {
      // Get all members with pagination
      const allMembers = [];
      let nextPageToken;

      do {
        const options = nextPageToken ? { pageToken: nextPageToken } : {};
        const result = AdminDirectory.Members.list(groupEmail, options);
        
        if (result.members) {
          allMembers.push(...result.members);
        }
        nextPageToken = result.nextPageToken;
      } while (nextPageToken);

      if (allMembers.length === 0) {
        statusCell.setValue('Done: No members to remove');
        processedCount++;
        continue;
      }

      // Remove all members
      let removedCount = 0;
      const errors = [];

      for (const member of allMembers) {
        try {
          AdminDirectory.Members.remove(groupEmail, member.email);
          removedCount++;
        } catch (error) {
          Logger.log(`Failed to remove ${member.email}: ${error.message}`);
          errors.push(member.email);
        }
      }

      if (errors.length > 0) {
        statusCell.setValue(`Partial: ${removedCount} of ${allMembers.length} removed. Failed: ${errors.length}`);
        errorCount++;
      } else {
        statusCell.setValue(`Done: ${removedCount} of ${allMembers.length} removed`);
        processedCount++;
      }
    } catch (error) {
      statusCell.setValue(`Failed: ${error.message}`);
      errorCount++;
    }
  }

  ui.alert(
    `Remove all group members complete.\n\n` +
    `Processed: ${processedCount}\n` +
    `Errors: ${errorCount}\n\n` +
    `Check "Status" column for details.`
  );
}

