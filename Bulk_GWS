/**
 * Adds users to multiple groups based on sheet data
 */
function addUserToMultipleGroups() {
  const ui = SpreadsheetApp.getUi();
  const confirmWord = CONFIG.CONFIRMATION_WORDS.ADD_MEMBERS;
  const message = `You are about to add users listed in Column A of the active sheet to the groups specified in Column B.\n\n` +
    `Ensure the data is correct.\n\n` +
    `Type "${confirmWord}" (all caps) to confirm.`;

  if (!showConfirmationDialog(confirmWord, 'Confirm Adding Users to Groups', message)) {
    ui.alert('Operation cancelled.');
    return;
  }

  const sheet = SpreadsheetApp.getActiveSpreadsheet().getActiveSheet();
  const data = sheet.getDataRange().getValues();

  // Validate Admin SDK access
  const validation = validateAdminSDK('Groups');
  if (!validation.valid) {
    ui.alert(`Error: ${validation.error}`);
    return;
  }

  // Find or create status column
  let statusColumn = data[0].length + 1;
  let statusHeaderExists = false;

  for (let col = 0; col < data[0].length; col++) {
    if (getCellValue(data[0][col]).toLowerCase() === 'status') {
      statusColumn = col + 1;
      statusHeaderExists = true;
      break;
    }
  }

  if (!statusHeaderExists) {
    sheet.getRange(1, statusColumn).setValue('Status').setFontWeight('bold');
  }

  let processedCount = 0;
  let errorCount = 0;

  // Process each row
  for (let i = 1; i < data.length; i++) {
    const userEmail = getCellValue(data[i][0]);
    const groupEmailsString = getCellValue(data[i][1]);
    const statusCell = sheet.getRange(i + 1, statusColumn);

    if (!userEmail) {
      statusCell.setValue(`Skipped: User email missing - ${new Date().toLocaleString()}`);
      continue;
    }

    if (!groupEmailsString) {
      statusCell.setValue(`Skipped: No groups provided`);
      continue;
    }

    const groupEmails = groupEmailsString
      .split(',')
      .map(email => email.trim())
      .filter(email => email);

    const errorMessages = [];
    const successMessages = [];

    for (const groupEmail of groupEmails) {
      try {
        // Check if already a member
        let isMember = false;
        try {
          AdminDirectory.Members.get(groupEmail, userEmail);
          isMember = true;
        } catch (error) {
          if (!error.message.includes('Resource Not Found') && !error.message.includes('notFound')) {
            throw error;
          }
        }

        if (isMember) {
          successMessages.push(`${groupEmail}: Already member`);
        } else {
          AdminDirectory.Members.insert(
            { email: userEmail, role: 'MEMBER' },
            groupEmail
          );
          successMessages.push(`${groupEmail}: Added`);
        }
      } catch (error) {
        errorMessages.push(`${groupEmail}: ${error.message}`);
      }
    }

    if (errorMessages.length > 0) {
      statusCell.setValue(`Errors: ${errorMessages.join('; ')}. Success: ${successMessages.join('; ')}`);
      errorCount++;
    } else {
      statusCell.setValue(`Done: ${successMessages.join('; ')}`);
      processedCount++;
    }
  }

  ui.alert(
    `Add users to groups complete.\n\n` +
    `Processed: ${processedCount}\n` +
    `Errors: ${errorCount}\n\n` +
    `Check "Status" column for details.`
  );
}

