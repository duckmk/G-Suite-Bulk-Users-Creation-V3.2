// SECTION 4: OFFBOARDING QUEUE
// ========================================

/**
 * Processes offboarding queue - suspends or deletes users immediately
 */
function processOffboardingQueue() {
  const ui = SpreadsheetApp.getUi();
  const confirmWord = CONFIG.CONFIRMATION_WORDS.REMOVE_USERS;
  const message = `You are about to process offboarding actions in '${CONFIG.BULK_REMOVE.SHEET_NAME}'.\n\n` +
    `This will suspend or delete users immediately based on the Action column.\n\n` +
    `Type "${confirmWord}" (all caps) to confirm.`;

  if (!showConfirmationDialog(confirmWord, 'Confirm Offboarding Processing', message)) {
    ui.alert('Offboarding processing cancelled.');
    return;
  }

  const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName(CONFIG.BULK_REMOVE.SHEET_NAME);
  if (!sheet) {
    ui.alert(`Sheet "${CONFIG.BULK_REMOVE.SHEET_NAME}" not found.`);
    return;
  }

  const data = sheet.getDataRange().getValues();
  if (data.length <= CONFIG.BULK_REMOVE.HEADER_ROWS) {
    ui.alert('No user data found.');
    return;
  }

  // Validate Admin SDK access
  const validation = validateAdminSDK('Users');
  if (!validation.valid) {
    ui.alert(`Error: ${validation.error}`);
    return;
  }

  // Setup headers if missing - using direct column numbers (1-indexed)
  if (!sheet.getRange(1, 1).getValue()) {
    sheet.getRange(1, 1).setValue('Action').setFontWeight('bold');
  }
  if (!sheet.getRange(1, 2).getValue()) {
    sheet.getRange(1, 2).setValue('Primary Email').setFontWeight('bold');
  }
  if (!sheet.getRange(1, 3).getValue()) {
    sheet.getRange(1, 3).setValue('Status').setFontWeight('bold');
  }
  if (!sheet.getRange(1, 4).getValue()) {
    sheet.getRange(1, 4).setValue('Last Updated').setFontWeight('bold');
  }

  const now = new Date();
  let suspendedCount = 0;
  let deletedCount = 0;
  let errorCount = 0;

  // Process each row
  for (let i = CONFIG.BULK_REMOVE.HEADER_ROWS; i < data.length; i++) {
    const action = getCellValue(data[i][0]).toLowerCase();  // Column A (index 0 in array)
    const email = getCellValue(data[i][1]);                 // Column B (index 1 in array)
    let statusMsg = '';
    const currentRow = i + 1;

    if (!email) {
      statusMsg = 'Skipped: Email missing';
      sheet.getRange(currentRow, 3).setValue(statusMsg);      // Column C
      sheet.getRange(currentRow, 4).setValue(formatDateTime(now)); // Column D
      continue;
    }

    try {
      if (action === 'suspend') {
        // Suspend user immediately
        AdminDirectory.Users.update({ suspended: true }, email);
        
        // Remove from all groups
        removeAllGroupsForUser(email);
        
        statusMsg = 'Suspended';
        suspendedCount++;
      } else if (action === 'delete') {
        // Delete user immediately
        AdminDirectory.Users.remove(email);
        statusMsg = 'Deleted';
        deletedCount++;
      } else {
        statusMsg = `Invalid action: ${action}`;
        errorCount++;
      }

      // Update status and last updated
      sheet.getRange(currentRow, 3).setValue(statusMsg);           // Column C
      sheet.getRange(currentRow, 4).setValue(formatDateTime(now)); // Column D
    } catch (error) {
      if (error.message.includes('Resource Not Found') || error.message.includes('notFound')) {
        statusMsg = 'Error: User not found';
      } else {
        statusMsg = `Error: ${error.message}`;
      }
      errorCount++;
      sheet.getRange(currentRow, 3).setValue(statusMsg);           // Column C
      sheet.getRange(currentRow, 4).setValue(formatDateTime(now)); // Column D
    }
  }

  ui.alert(
    `Offboarding processing complete.\n\n` +
    `Suspended: ${suspendedCount}\n` +
    `Deleted: ${deletedCount}\n` +
    `Errors: ${errorCount}\n\n` +
    `Check "${CONFIG.BULK_REMOVE.SHEET_NAME}" sheet for details.`
  );
}

/**
 * Removes user from all groups in the domain
 * @param {string} email - User's email address
 */
function removeAllGroupsForUser(email) {
  try {
    const domain = Session.getEffectiveUser().getEmail().split('@')[1];
    let allGroups = [];
    let nextPageToken;

    // Get all groups with pagination
    do {
      const options = { domain, maxResults: 200 };
      if (nextPageToken) options.pageToken = nextPageToken;
      
      const result = AdminDirectory.Groups.list(options);
      if (result.groups) {
        allGroups.push(...result.groups);
      }
      nextPageToken = result.nextPageToken;
    } while (nextPageToken);

    if (!allGroups || allGroups.length === 0) {
      Logger.log(`No groups found in domain ${domain}`);
      return;
    }

    // Remove user from each group
    let removedCount = 0;
    let failedCount = 0;

    for (const group of allGroups) {
      try {
        AdminDirectory.Members.remove(group.email, email);
        Logger.log(`✅ Removed ${email} from ${group.email}`);
        removedCount++;
      } catch (error) {
        // User might not be in this group - that's ok
        if (!error.message.includes('Resource Not Found') && !error.message.includes('notFound')) {
          Logger.log(`❌ Failed to remove ${email} from ${group.email}: ${error.message}`);
          failedCount++;
        }
      }
    }

    Logger.log(`Group removal summary for ${email}: ${removedCount} removed, ${failedCount} failed`);
  } catch (error) {
    Logger.log(`❌ Failed to process groups for ${email}: ${error.message}`);
  }
}
