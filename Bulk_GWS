/**
 * Formats date object to standardized string
 * @param {Date} dateObject - Date to format
 * @returns {string} Formatted date string
 */
function formatDateTime(dateObject) {
  if (!dateObject || !(dateObject instanceof Date) || isNaN(dateObject)) {
    return '';
  }
  return Utilities.formatDate(
    dateObject,
    Session.getScriptTimeZone(),
    'yyyy-MM-dd HH:mm:ss z'
  );
}

/**
 * Safely gets cell value as trimmed string
 * @param {*} value - Cell value
 * @returns {string} Trimmed string value
 */
function getCellValue(value) {
  return (value || '').toString().trim();
}

/**
 * Validates Admin SDK access
 * @param {string} service - Service to validate ('Users' or 'Groups')
 * @returns {Object} {valid: boolean, error: string}
 */
function validateAdminSDK(service = 'Users') {
  try {
    const domain = Session.getEffectiveUser().getEmail().split('@')[1];
    if (service === 'Groups') {
      AdminDirectory.Groups.list({ maxResults: 1, domain });
    } else {
      AdminDirectory.Users.list({ maxResults: 1, domain });
    }
    return { valid: true, error: null };
  } catch (error) {
    return {
      valid: false,
      error: `Admin SDK not enabled or insufficient permissions: ${error.message}`
    };
  }
}

/**
 * Shows confirmation dialog and validates response
 * @param {string} confirmationWord - Required confirmation word
 * @param {string} title - Dialog title
 * @param {string} message - Dialog message
 * @returns {boolean} True if confirmed
 */
function showConfirmationDialog(confirmationWord, title, message) {
  const ui = SpreadsheetApp.getUi();
  const response = ui.prompt(title, message, ui.ButtonSet.OK_CANCEL);
  return (
    response.getSelectedButton() === ui.Button.OK &&
    response.getResponseText() === confirmationWord
  );
}

/**
 * Fetches department of a manager
 * @param {string} managerEmail - Manager's email address
 * @returns {string|null} Manager's department or null
 */
function getManagerDepartment(managerEmail) {
  if (!managerEmail) return null;
  
  try {
    const manager = AdminDirectory.Users.get(managerEmail);
    return manager.organizations?.[0]?.department || null;
  } catch (error) {
    Logger.log(`Could not fetch department for manager ${managerEmail}: ${error.message}`);
    return null;
  }
}

/**
 * Updates status cell with message and timestamp
 * @param {Sheet} sheet - Sheet object
 * @param {number} row - Row number (1-indexed)
 * @param {number} col - Column number (1-indexed)
 * @param {string} message - Status message
 * @param {Date} timestamp - Timestamp
 */
function updateStatusCell(sheet, row, col, message, timestamp = new Date()) {
  sheet.getRange(row, col).setValue(message);
  if (col !== CONFIG.COLUMNS.LASTUPDATED + 1) {
    sheet.getRange(row, CONFIG.COLUMNS.LASTUPDATED + 1).setValue(formatDateTime(timestamp));
  }
}

// ========================================
// SECTION 1: USER ACCOUNT MANAGEMENT
// ========================================

/**
 * Main function to process user creation and update actions
 */
function processUserActions() {
  const ui = SpreadsheetApp.getUi();
  const confirmWord = CONFIG.CONFIRMATION_WORDS.PROCESS_USERS;
  const message = `You are about to process user creation and update actions based on the data in the '${CONFIG.USER_DATA.SHEET_NAME}' sheet.\n\n` +
    `This may create new user accounts or modify existing ones.\n` +
    `This action is irreversible for successful operations.\n\n` +
    `Type "${confirmWord}" (all caps) to confirm.`;

  if (!showConfirmationDialog(confirmWord, 'Confirm User Account Processing', message)) {
    ui.alert('User account processing cancelled.');
    return;
  }

  const sheet = SpreadsheetApp.getActiveSpreadsheet().getSheetByName(CONFIG.USER_DATA.SHEET_NAME);
  if (!sheet) {
    ui.alert(`Sheet "${CONFIG.USER_DATA.SHEET_NAME}" not found.`);
    return;
  }

  // Validate Admin SDK access
  const validation = validateAdminSDK('Users');
  if (!validation.valid) {
    ui.alert(`Error: ${validation.error}`);
    return;
  }

  const data = sheet.getDataRange().getValues();
  const now = new Date();
  let processedCount = 0;
  let errorCount = 0;

  for (let i = CONFIG.USER_DATA.HEADER_ROWS; i < data.length; i++) {
    const row = data[i];
    const action = getCellValue(row[CONFIG.COLUMNS.ACTION]).toLowerCase();
    const primaryEmail = getCellValue(row[CONFIG.COLUMNS.PRIMARYEMAIL]);
    
    if (!primaryEmail) {
      updateStatusCell(
        sheet,
        i + 1,
        CONFIG.COLUMNS.STATUS + 1,
        'Error: PrimaryEmail (Col D) is mandatory',
        now
      );
      errorCount++;
      continue;
    }

    let status = '';
    try {
      if (action === 'create') {
        status = createUserInWorkspace(row, now);
      } else if (action === 'update') {
        status = updateUserInWorkspace(row, now);
      } else {
        status = `Skipped at ${formatDateTime(now)} - Invalid action: ${row[CONFIG.COLUMNS.ACTION]}`;
      }
      
      if (!status.includes('Error')) {
        processedCount++;
      } else {
        errorCount++;
      }
    } catch (error) {
      Logger.log(`Error processing row ${i + 1} for ${primaryEmail}: ${error.message}`);
      status = `Error at ${formatDateTime(now)}: ${error.message}`;
      errorCount++;
    }

    updateStatusCell(sheet, i + 1, CONFIG.COLUMNS.STATUS + 1, status, now);
  }

  ui.alert(
    `Processing complete.\n\n` +
    `Processed: ${processedCount}\n` +
    `Errors: ${errorCount}\n\n` +
    `Check "Status" (Col L) and "Last Updated" (Col M) for details.`
  );
}

/**
 * Creates a new user in Google Workspace
 * @param {Array} userDataRow - Row data from sheet
 * @param {Date} timestamp - Current timestamp
 * @returns {string} Status message
 */
function createUserInWorkspace(userDataRow, timestamp) {
  const firstName = getCellValue(userDataRow[CONFIG.COLUMNS.FIRSTNAME]);
  const lastName = getCellValue(userDataRow[CONFIG.COLUMNS.LASTNAME]);
  const primaryEmail = getCellValue(userDataRow[CONFIG.COLUMNS.PRIMARYEMAIL]);
  const password = getCellValue(userDataRow[CONFIG.COLUMNS.PASSWORD]);
  const orgUnitPath = getCellValue(userDataRow[CONFIG.COLUMNS.ORGUNIT]) || CONFIG.DEFAULT_ORG_UNIT;
  const recoveryMobile = getCellValue(userDataRow[CONFIG.COLUMNS.RECOVERYMOBILE]);
  const recoveryEmail = getCellValue(userDataRow[CONFIG.COLUMNS.RECOVERYEMAIL]);
  const managerEmail = getCellValue(userDataRow[CONFIG.COLUMNS.MANAGEREMAIL]);
  const jobTitle = getCellValue(userDataRow[CONFIG.COLUMNS.JOBTITLE]);
  let department = getCellValue(userDataRow[CONFIG.COLUMNS.DEPARTMENT]);

  // Validate required fields
  if (!firstName || !lastName || !primaryEmail || !password) {
    return `Error creating ${primaryEmail} at ${formatDateTime(timestamp)}: Missing required fields (FirstName, LastName, Email, Password).`;
  }

  // Auto-fill department from manager if empty
  if (!department && managerEmail) {
    const mgrDept = getManagerDepartment(managerEmail);
    if (mgrDept) department = mgrDept;
  }

  // Build user object
  const user = {
    primaryEmail,
    name: {
      givenName: firstName,
      familyName: lastName
    },
    password,
    orgUnitPath,
    changePasswordAtNextLogin: true
  };

  // Add optional fields
  if (recoveryMobile) {
    user.recoveryPhone = recoveryMobile;
  }
  if (recoveryEmail) {
    user.recoveryEmail = recoveryEmail;
  }
  if (managerEmail) {
    user.relations = [{
      value: managerEmail,
      type: 'manager'
    }];
  }
  if (jobTitle || department) {
    user.organizations = [{}];
    if (jobTitle) user.organizations[0].title = jobTitle;
    if (department) user.organizations[0].department = department;
  }

  try {
    AdminDirectory.Users.insert(user);
    Logger.log(`User ${primaryEmail} created successfully.`);
    return `User created successfully at ${formatDateTime(timestamp)}.`;
  } catch (error) {
    Logger.log(`Failed to create user ${primaryEmail}. Error: ${error.message}`);
    if (error.message.includes('EntityExists')) {
      return `Error: User already exists.`;
    }
    return `Error creating ${primaryEmail}: ${error.message}`;
  }
}

/**
 * Updates an existing user in Google Workspace
 * @param {Array} userDataRow - Row data from sheet
 * @param {Date} timestamp - Current timestamp
 * @returns {string} Status message
 */
function updateUserInWorkspace(userDataRow, timestamp) {
  const primaryEmail = getCellValue(userDataRow[CONFIG.COLUMNS.PRIMARYEMAIL]);
  const newFirstName = getCellValue(userDataRow[CONFIG.COLUMNS.FIRSTNAME]);
  const newLastName = getCellValue(userDataRow[CONFIG.COLUMNS.LASTNAME]);
  const newPassword = getCellValue(userDataRow[CONFIG.COLUMNS.PASSWORD]);
  const newOrgUnitPath = getCellValue(userDataRow[CONFIG.COLUMNS.ORGUNIT]);
  const recoveryMobile = getCellValue(userDataRow[CONFIG.COLUMNS.RECOVERYMOBILE]);
  const recoveryEmail = getCellValue(userDataRow[CONFIG.COLUMNS.RECOVERYEMAIL]);
  const managerEmailInput = getCellValue(userDataRow[CONFIG.COLUMNS.MANAGEREMAIL]);
  const jobTitle = getCellValue(userDataRow[CONFIG.COLUMNS.JOBTITLE]);
  let department = getCellValue(userDataRow[CONFIG.COLUMNS.DEPARTMENT]);

  if (!primaryEmail) {
    return `Error updating user: PrimaryEmail is required.`;
  }

  try {
    const existingUser = AdminDirectory.Users.get(primaryEmail);
    const userPatch = {};
    let hasChanges = false;

    // Update first name
    if (newFirstName && existingUser.name.givenName !== newFirstName) {
      if (!userPatch.name) userPatch.name = {};
      userPatch.name.givenName = newFirstName;
      hasChanges = true;
    }

    // Update last name
    if (newLastName && existingUser.name.familyName !== newLastName) {
      if (!userPatch.name) userPatch.name = {};
      userPatch.name.familyName = newLastName;
      hasChanges = true;
    }

    // Update password
    if (newPassword) {
      userPatch.password = newPassword;
      userPatch.changePasswordAtNextLogin = true;
      hasChanges = true;
    }

    // Update org unit
    if (newOrgUnitPath && existingUser.orgUnitPath !== newOrgUnitPath) {
      userPatch.orgUnitPath = newOrgUnitPath;
      hasChanges = true;
    }

    // Update recovery mobile
    const currentMobile = existingUser.phones?.[0]?.value || '';
    if (recoveryMobile && currentMobile !== recoveryMobile) {
      userPatch.phones = [{
        value: recoveryMobile,
        type: 'mobile',
        primary: true
      }];
      hasChanges = true;
    }

    // Update recovery email
    if (recoveryEmail && existingUser.recoveryEmail !== recoveryEmail) {
      userPatch.recoveryEmail = recoveryEmail;
      hasChanges = true;
    }

    // Update manager (only if provided)
    const currentRelations = existingUser.relations || [];
    const currentManager = currentRelations.find(r => r.type === 'manager')?.value || '';
    if (managerEmailInput && managerEmailInput !== currentManager) {
      userPatch.relations = [{
        value: managerEmailInput,
        type: 'manager'
      }];
      hasChanges = true;
    }

    // Auto-fill department from manager if empty and manager is provided
    if (!department && managerEmailInput) {
      const mgrDept = getManagerDepartment(managerEmailInput);
      if (mgrDept) department = mgrDept;
    }

    // Update job title and department
    const currentOrg = existingUser.organizations?.[0] || {};
    const currentDept = currentOrg.department || '';
    const currentTitle = currentOrg.title || '';

    if ((jobTitle && jobTitle !== currentTitle) || (department && department !== currentDept)) {
      if (!userPatch.organizations) userPatch.organizations = [{}];
      if (jobTitle && jobTitle !== currentTitle) {
        userPatch.organizations[0].title = jobTitle;
      }
      if (department && department !== currentDept) {
        userPatch.organizations[0].department = department;
      }
      hasChanges = true;
    }

    if (!hasChanges) {
      return `No changes detected for ${primaryEmail}. Skipped update.`;
    }

    AdminDirectory.Users.update(userPatch, primaryEmail);
    Logger.log(`User ${primaryEmail} updated successfully.`);
    return `User updated successfully at ${formatDateTime(timestamp)}.`;
  } catch (error) {
    if (error.message.includes('Resource Not Found') || error.message.includes('notFound')) {
      return `Error: User not found.`;
    }
    Logger.log(`Failed to update user ${primaryEmail}. Error: ${error.message}`);
    return `Error updating ${primaryEmail}: ${error.message}`;
  }
}

