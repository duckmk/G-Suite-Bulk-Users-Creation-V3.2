  USER_DATA: {
    SHEET_NAME: 'G Suite Bulk User Creation',
    HEADER_ROWS: 1
  },
  BULK_REMOVE: {
    SHEET_NAME: 'BulkRemove|OFFBOARDING',
    HEADER_ROWS: 1
  },
  OFFBOARDING_COLUMNS: {
    ACTION: 0,        // A: Action (suspend/delete)
    PRIMARYEMAIL: 1,  // B: Primary Email
    STATUS: 2         // C: Status
  },

  COLUMNS: {
    ACTION: 0,            // A: Action (create/update)
    FIRSTNAME: 1,         // B: First Name
    LASTNAME: 2,          // C: Last Name
    PRIMARYEMAIL: 3,      // D: Primary Email Address
    PASSWORD: 4,          // E: Password
    ORGUNIT: 5,           // F: Organizational Unit Path
    RECOVERYMOBILE: 6,    // G: Recovery Mobile
    RECOVERYEMAIL: 7,     // H: Recovery Email
    MANAGEREMAIL: 8,      // I: Manager Email
    JOBTITLE: 9,          // J: Job Title
    DEPARTMENT: 10,       // K: Department
    STATUS: 11,           // L: Status
    LASTUPDATED: 12.      // M: Last Updated
  },
  CONFIRMATION_WORDS: {
    PROCESS_USERS: 'PROCESSUSERS',
    ADD_MEMBERS: 'ADDMEMBERS',
    EMPTY_GROUPS: 'EMPTYGROUPS',
    REMOVE_USERS: 'REMOVEUSERS'
  },
  DEFAULT_ORG_UNIT: '/'
};

